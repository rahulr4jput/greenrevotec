# Auto-detect text files and normalize line endings
* text=auto

# Force LF for these file types on all platforms
*.js    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.toml  text eol=lf
*.env   text eol=lf
*.sh    text eol=lf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.mp4   binary
*.webp  binary
*.svg   binary
